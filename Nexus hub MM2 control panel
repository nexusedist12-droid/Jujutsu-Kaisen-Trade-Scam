-- FUNCIÓN TOGGLE (SOLO VISUAL)
local function makeToggle(text, yPos)
	local base = Instance.new("Frame", main)
	base.Size = UDim2.new(0.9, 0, 0, 32)
	base.Position = UDim2.new(0.5, 0, 0, yPos)
	base.AnchorPoint = Vector2.new(0.5, 0)
	base.BackgroundColor3 = Color3.fromRGB(30, 35, 40)
	base.BackgroundTransparency = 0.2
	base.BorderSizePixel = 0
	Instance.new("UICorner", base).CornerRadius = UDim.new(0, 6)

	local txt = Instance.new("TextLabel", base)
	txt.Size = UDim2.new(1, -55, 1, 0)
	txt.Position = UDim2.new(0, 10, 0, 0)
	txt.BackgroundTransparency = 1
	txt.Text = text
	txt.TextColor3 = Color3.fromRGB(220, 255, 220)
	txt.TextSize = 14
	txt.Font = Enum.Font.Gotham
	txt.TextXAlignment = Enum.TextXAlignment.Left

	local btn = Instance.new("TextButton", base)
	btn.Size = UDim2.new(0, 40, 0, 20)
	btn.Position = UDim2.new(1, -45, 0.5, -10)
	btn.BackgroundColor3 = Color3.fromRGB(60, 70, 80)
	btn.Text = ""
	btn.BorderSizePixel = 0
	Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

	local dot = Instance.new("Frame", btn)
	dot.Size = UDim2.new(0, 16, 0, 16)
	dot.Position = UDim2.new(0, 2, 0.5, -8)
	dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	dot.BorderSizePixel = 0
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local on = false
	btn.MouseButton1Click:Connect(function()
		on = not on
		TS:Create(btn, TweenInfo.new(0.2), {
			BackgroundColor3 = on and Color3.fromRGB(0,255,120) or Color3.fromRGB(60,70,80)
		}):Play()
		TS:Create(dot, TweenInfo.new(0.2), {
			Position = on and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
		}):Play()
	end)
end

-- OPCIONES (SOLO DISEÑO)
makeToggle("Freeze Trade", 45)
makeToggle("Auto Accept", 85)
makeToggle("Auto Item", 125)

-- SISTEMA MOVIBLE
local dragging, dragInput, dragStart, startPos

local function update(input)
	local delta = input.Position - dragStart
	main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
		startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

main.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = main.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

main.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		update(input)
	end
end)
